NODE_ENV=development
HOST=0.0.0.0
PORT=4000

DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=documents

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=384
AI_TIMEOUT_MS=12000

RETRIEVAL_MODE=fts

JWT_SECRET=replace_with_a_long_random_secret_of_32_chars_or_more
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=doc_analyzer_token
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_HOUR=6

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
OTP_REQUEST_IP_RATE_LIMIT_MAX=30
OTP_VERIFY_IP_RATE_LIMIT_MAX=40
UPLOAD_RATE_LIMIT_MAX=20
CHAT_RATE_LIMIT_MAX=60

MAX_REQUEST_BODY_SIZE=1mb
MAX_FILE_SIZE_MB=10
MAX_UPLOAD_FILE_SIZE_BYTES=10485760
MAX_PAGES_PER_DOC=40
MAX_CHUNKS_PER_DOC=200
MAX_CHAT_REQUESTS_PER_DAY=20
MAX_DOCS_PER_CHAT=3

CHAT_HISTORY_LIMIT=8
CHAT_MESSAGE_LIST_LIMIT=200
RAG_TOP_K=6
RAG_CANDIDATE_PAGE_SIZE=24
RAG_TOKEN_TO_CHAR_RATIO=4
RAG_CHUNK_TOKENS=1000
RAG_CHUNK_OVERLAP_TOKENS=200

ENABLE_DOCUMENT_WORKER=true
WORKER_POLL_INTERVAL_MS=1000
DOCUMENT_PROCESSING_RETRY_AFTER_MS=900000

GITHUB_REPOSITORY_URL=https://github.com/saahilpal/RAG-DOCAnalyzer
RUN_LOCALLY_GUIDE_URL=https://github.com/saahilpal/RAG-DOCAnalyzer#quick-start

EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="DocAnalyzer <your_gmail_address@gmail.com>"
MAIL_RETRY_ATTEMPTS=3
MAIL_RETRY_BACKOFF_MS=300
